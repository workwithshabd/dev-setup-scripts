#!/usr/bin/env bash
set -e

# -------- HELP --------
show_help() {
  echo ""
  echo "MERN Setup CLI"
  echo ""
  echo "Usage:"
  echo "  mern-setup [project] [mongo_uri] [jwt_secret] [frontend_url]"
  echo ""
  echo "Examples:"
  echo "  mern-setup"
  echo "  mern-setup myapp"
  echo "  mern-setup myapp mongodb://localhost:27017 devsecret http://localhost:3000"
  echo ""
}

if [[ "${1:-}" == "-help" || "${1:-}" == "--help" ]]; then
  show_help
  exit 0
fi

echo ""
echo "==========================================="
echo "        MERN Setup"
echo "==========================================="
echo ""

# -------- DEPENDENCY CHECK --------
if ! command -v node >/dev/null 2>&1; then
  echo "❌ Node.js is not installed."
  echo "Install Node.js and re-run."
  exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "❌ npm is not installed."
  exit 1
fi

# -------- INPUT --------
APP_NAME=${1:-}
MONGO_URI=${2:-}
JWT_SECRET=${3:-}
FRONTEND_URL=${4:-}

# -------- INTERACTIVE FALLBACK --------

if [[ -z "$APP_NAME" ]]; then
  read -p "Project name (default: mern-app): " INPUT < /dev/tty
  APP_NAME=${INPUT:-mern-app}
fi

if [[ -z "$MONGO_URI" ]]; then
  read -p "MongoDB URI (leave blank to fill later): " INPUT < /dev/tty
  MONGO_URI=${INPUT:-your_mongodb_connection_string_here}
fi

if [[ -z "$JWT_SECRET" ]]; then
  read -p "JWT Secret (default: devsecret): " INPUT < /dev/tty
  JWT_SECRET=${INPUT:-devsecret}
fi

if [[ -z "$FRONTEND_URL" ]]; then
  read -p "Frontend URL (default: http://localhost:5173): " INPUT < /dev/tty
  FRONTEND_URL=${INPUT:-http://localhost:5173}
fi

# -------- CONFIRM --------
echo ""
echo "-------------------------------------------"
echo "Confirm Setup:"
echo "Project: $APP_NAME"
echo "Mongo URI: $MONGO_URI"
echo "Frontend URL: $FRONTEND_URL"
echo "-------------------------------------------"

read -p "Continue? (y/n): " CONFIRM < /dev/tty
if [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]]; then
  echo "Setup cancelled."
  exit 0
fi

# -------- ROOT --------
mkdir "$APP_NAME"
cd "$APP_NAME"

# =========================
# BACKEND
# =========================
echo "Setting up backend..."
mkdir backend
cd backend

npm init -y >/dev/null
npm install express mongoose cors dotenv >/dev/null
npm install nodemon --save-dev >/dev/null

node -e "
let pkg=require('./package.json');
pkg.scripts={dev:'nodemon server.js',start:'node server.js'};
require('fs').writeFileSync('package.json', JSON.stringify(pkg,null,2));
"

mkdir controllers models routes middleware

cat <<EOF > models/appModel.js
const mongoose = require('mongoose');

const appSchema = new mongoose.Schema({
  message: { type: String, required: true }
}, { timestamps: true });

module.exports = mongoose.model('App', appSchema);
EOF

cat <<EOF > controllers/appController.js
const App = require('../models/appModel');

exports.getApi = async (req, res, next) => {
  try {
    const data = await App.findOne();
    res.json(data || { message: "API running" });
  } catch (err) {
    next(err);
  }
};
EOF

cat <<EOF > routes/appRoutes.js
const express = require('express');
const router = express.Router();
const { getApi } = require('../controllers/appController');

router.get('/', getApi);

module.exports = router;
EOF

cat <<EOF > middleware/corsMiddleware.js
const cors = require('cors');

module.exports = cors({
  origin: process.env.FRONTEND_URL || 'http://localhost:5173',
  credentials: true
});
EOF

cat <<EOF > middleware/errorMiddleware.js
module.exports = (err, req, res, next) => {
  console.error(err.stack);
  res.status(500).json({ message: err.message || "Server Error" });
};
EOF

cat <<EOF > server.js
const express = require('express');
const mongoose = require('mongoose');
require('dotenv').config();

const corsMiddleware = require('./middleware/corsMiddleware');
const errorMiddleware = require('./middleware/errorMiddleware');
const appRoutes = require('./routes/appRoutes');

const app = express();

app.use(corsMiddleware);
app.use(express.json());

app.use('/api', appRoutes);

mongoose.connect(process.env.MONGO_URI)
  .then(() => console.log('MongoDB Connected'))
  .catch(err => console.log(err));

const PORT = process.env.PORT || 5000;

app.use(errorMiddleware);

app.listen(PORT, () => {
  console.log(\`Server running on port \${PORT}\`);
});
EOF

cat <<EOF > .env
PORT=5000
MONGO_URI=$MONGO_URI
JWT_SECRET=$JWT_SECRET
FRONTEND_URL=$FRONTEND_URL
EOF

cd ..

# =========================
# FRONTEND
# =========================
echo "Setting up frontend..."
npm create vite@latest frontend -- --template react >/dev/null
cd frontend

npm install >/dev/null
npm install -D tailwindcss postcss autoprefixer >/dev/null

# Fix: avoid npx bug
if [ -f "./node_modules/.bin/tailwindcss" ]; then
  ./node_modules/.bin/tailwindcss init -p
else
  echo "❌ Tailwind CLI not found"
  exit 1
fi

cat <<EOF > tailwind.config.js
export default {
  content: ["./index.html","./src/**/*.{js,ts,jsx,tsx}"],
  theme: { extend: {} },
  plugins: [],
}
EOF

cat <<EOF > src/index.css
@tailwind base;
@tailwind components;
@tailwind utilities;
EOF

cat <<EOF > src/App.jsx
import { useEffect, useState } from "react";

function App() {
  const [msg, setMsg] = useState("");

  useEffect(() => {
    fetch("http://localhost:5000/api")
      .then(res => res.json())
      .then(data => setMsg(data.message));
  }, []);

  return (
    <div className="flex items-center justify-center h-screen">
      <h1 className="text-3xl font-bold text-blue-600">
        {msg || "Loading..."}
      </h1>
    </div>
  );
}

export default App;
EOF

cd ..

# =========================
# SUCCESS
# =========================
echo ""
echo "==========================================="
echo "   ✅ MERN Project Created Successfully"
echo "==========================================="
echo ""

echo "Project: $APP_NAME"
echo ""
echo "Run backend:"
echo "  cd $APP_NAME/backend && npm run dev"
echo ""
echo "Run frontend:"
echo "  cd $APP_NAME/frontend && npm run dev"
echo ""
echo "Frontend: http://localhost:5173"
echo "Backend API: http://localhost:5000/api"
echo ""
echo "⚠️ Update MongoDB URI in backend/.env"
echo ""
echo "🚀 Ready to build!"